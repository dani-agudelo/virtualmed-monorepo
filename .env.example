# =============================================================================
# VirtualMed — único archivo de secretos y URLs (monorepo)
# Copiar:  cp .env.example .env
# Docker:  docker compose up -d
# Local:   backend carga este .env; frontend: scripts/sync-frontend-env.sh
# =============================================================================

# ── Base de datos ────────────────────────────────────────────────────────────
POSTGRES_CONNECTION="Host=TU_HOST;Port=5432;Database=TU_DB;Username=TU_USER;Password=TU_PASSWORD;SSL Mode=Require;Trust Server Certificate=true"

# ── Backend (.NET) ───────────────────────────────────────────────────────────
JWT_KEY=change-me-in-production-min-32-chars-virtualmed
ENCRYPTION_KEY=change-me-encryption-key-min-16-chars

# MinIO — documentos de soporte al registrar médicos (NO es el RAG del chatbot)
# Docker Compose: minio:9000 | dotnet run local con MinIO en Docker: localhost:9000
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=virtualmed
MINIO_SECRET_KEY=VirtualMed123
MINIO_BUCKET=doctor-documents
MINIO_USE_SSL=false

# Twilio (WebRTC / video consulta)
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=

# SendGrid / correo (opcional)
EMAIL_ENABLED=false
EMAIL_FROM=
EMAIL_FROM_NAME=VirtualMed
EMAIL_API_KEY=
EMAIL_FRONTEND_BASE_URL=http://localhost:3000
EMAIL_ADMIN_NOTIFICATION=

# Risk ML — local sin Docker: :8001; Docker Compose lo sobreescribe internamente
RISK_PREDICTION_BASE_URL=http://localhost:8001

# ── Chatbot (contenedor chatbot) ─────────────────────────────────────────────
GEMINI_API_KEY=
NVIDIA_API_KEY=
EMBED_MODEL=baai/bge-m3
INTERNAL_API_KEY=virtualmed-internal-dev-key

# ── Frontend (URLs desde el NAVEGADOR — se incluyen al construir la imagen) ──
NEXT_PUBLIC_API_URL=http://localhost:5045/api
NEXT_PUBLIC_WS_URL=ws://localhost:5045/hubs/video-chat
NEXT_PUBLIC_AI_URL=http://localhost:8000
NEXT_PUBLIC_CHATBOT_INTERNAL_API_KEY=virtualmed-internal-dev-key
