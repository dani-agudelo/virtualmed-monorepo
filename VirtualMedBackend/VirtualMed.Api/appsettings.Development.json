{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.AspNetCore": "Information",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "System": "Information"
      }
    }
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": false
  },
  "ClientRateLimiting": {
    "EnableEndpointRateLimiting": false
  },
  "RiskPrediction": {
    "BaseUrl": "http://localhost:8001",
    "TimeoutSeconds": 10
  }
}
